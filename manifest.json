{
  "manifest_version": 3,
  "name": "AD'IOS",
  "short_name": "AD'IOS",
  "version": "2.0.0",
  "description": "Say goodbye to YouTube ads. AD'IOS skips pre-rolls, closes overlays and silences unskippable ads — instantly, locally, silently.",

  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "AD'IOS",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
